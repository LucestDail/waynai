# ============================================================
# WaynAI 환경변수 템플릿
# ============================================================
# 1) 이 파일을 복사하여 `.env` 를 만드세요: cp .env.example .env
# 2) 각 키를 발급받아 채워 넣으세요.
# 3) `.env` 는 절대로 커밋하지 마세요 (.gitignore 포함됨).
# ------------------------------------------------------------

# ---- Gemini (Google AI Studio) ----
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=

# 모델 호출 우선순위 (저가 → 고가). 실패 시 다음 모델로 핫스왑 fallback.
GEMINI_MODEL_CHAIN=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash,gemini-2.5-flash,gemini-2.5-pro

# ---- 네이버 검색 API ----
# https://developers.naver.com/apps 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- 한국관광공사 공공데이터 서비스 키 ----
# https://www.data.go.kr/ 에서 활용 신청 후 발급
# ⚠️ 반드시 "Decoding(원문)" 값을 넣으세요. (내부에서 자동으로 URL 인코딩함)
# 값에 +, /, = 이 포함되므로 따옴표로 감싸는 것을 권장합니다.
#   예) TOUR_API_SERVICE_KEY="+kU/l+mB...원문...=="
TOUR_API_SERVICE_KEY=

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- 서버 ----
SERVER_PORT=8080

# ---- 프론트엔드 (Vite) ----
VITE_API_BASE_URL=http://localhost:8080
